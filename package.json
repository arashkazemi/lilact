{
  "name": "lilact",
  "version": "0.10.2",
  "description": "A Little React/JSX Runtime Implementation for Browser",
  "repository": "github:arashkazemi/lilact",
  "homepage": "https://arashkazemi.github.io/lilact/",
  "keywords": [
    "jsx",
    "transpiler",
    "react",
    "legacy",
    "hook",
    "component",
    "lightweight",
    "bundle",
    "runtime"
  ],
  "main": "src/lilact.jsx",
  "type": "module",
  "scripts": {
    "http": "http-server root",
    "doc": "bin/transpile-dir.js --inDir src --outDir .tmp && npx typedoc --out docs --tsconfig tsconfig.json && bin/copy-demo.js",
    "build:debug": "webpack --mode development",
    "build:release": "webpack --mode production",
    "build:debug.min": "webpack --mode development --env minify=true",
    "build:release.min": "webpack --mode production --env minify=true",
    "build": "npm-run-all build:debug.min build:debug build:release.min doc"
  },
  "bin": {
    "transpile": "./bin/transpile.js",
    "lilact-bundler": "./bin/bundle.cjs"
  },
  "author": "Arash Kazemi <contact.arash.kazemi@gmail.com>",
  "license": "BSD-2-Clause",
  "devDependencies": {
    "http-server": "^14.1.1",
    "npm-run-all": "^4.1.5",
    "typedoc": "^0.28.19",
    "webpack-cli": "^6.0.1",
    "webpack-dev": "^1.1.1"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "css-loader": "^7.1.4",
    "prop-types": "^15.8.1",
    "redux": "^5.0.1",
    "style-loader": "^4.0.0",
    "webpack": "^5.97.1"
  },
  "exports": {
    ".": "./dist/lilact.development.js",
    "./package.json": "./package.json"
  }
}
